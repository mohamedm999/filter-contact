# ═══════════════════════════════════════════════════════════
#  CENTRALIZED CONFIGURATION — Copy this to .env and fill in
#  ⚠️  NEVER commit .env to Git!
# ═══════════════════════════════════════════════════════════

# ── SMTP / Gmail ──
EMAIL_USERNAME=your.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Sender Profile ──
SENDER_NAME=Your Name
SENDER_EMAIL=your.email@gmail.com
SENDER_PHONE=+212 000 000 000

# ── OpenAI (for AI email generation) ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── OpenRouter (fallback when OpenAI fails) ──
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── File Paths (leave empty to use defaults) ──
CONTACTS_FILE=
LOG_DIR=

# ── Campaign Settings ──
DRY_RUN=true
MIN_RELEVANCE_STARS=1
MAX_EMAILS_PER_DAY=40
MAX_EMAILS_PER_HOUR=15
BATCH_SIZE=10
BATCH_PAUSE_MINUTES=15
