# ═══════════════════════════════════════════════════════════
#  CENTRALIZED CONFIGURATION — Copy this to .env and fill in
#  ⚠️  NEVER commit .env to Git!
# ═══════════════════════════════════════════════════════════

# ── SMTP / Gmail ──
EMAIL_USERNAME=your.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Sender Profile ──
SENDER_NAME=Your Name
SENDER_EMAIL=your.email@gmail.com
SENDER_PHONE=+212 000 000 000

# ── LinkedIn Credentials (for scraping) ──
LINKEDIN_EMAIL=your-linkedin-email
LINKEDIN_PASSWORD=your-linkedin-password

# ── OpenAI (for AI email generation) ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── OpenRouter (fallback when OpenAI fails) ──
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── File Paths (leave empty to use defaults) ──
CONTACTS_FILE=
LOG_DIR=

# ── Campaign Settings ──
DRY_RUN=true
MIN_RELEVANCE_STARS=1
MAX_EMAILS_PER_DAY=40
MAX_EMAILS_PER_HOUR=15
BATCH_SIZE=10
BATCH_PAUSE_MINUTES=15

# ── Professional Email Signature ──
SIGNATURE_TITLE=Développeur Web Full Stack
SIGNATURE_PORTFOLIO=https://code-folio-portfolio-personnel-fron.vercel.app/
SIGNATURE_GITHUB=https://github.com/mohamedm999
SIGNATURE_LINKEDIN=https://www.linkedin.com/in/mohamed-moukhtari-197a53338/
SIGNATURE_LOGO_URL=
SIGNATURE_ACCENT_COLOR=#2563EB

# ── CV Attachment Settings ──
CV_PATH_FR=email_campaign/cv/cv_fr.pdf
CV_PATH_EN=email_campaign/cv/cv_en.pdf
ATTACH_CV=true